generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ResourceType {
  HOT_WATER
  COLD_WATER
  HEATING
  ELECTRICITY
}

enum SessionStatus {
  DRAFT
  IN_PROGRESS
  COMPLETED
  EXPORTED
}

enum ReadingStatus {
  OK
  WARNING
  CORRECTED
  CANCELLED
}

enum ReadingSource {
  DAH
  COLLECTED
}


model Building {
  id        String   @id @default(cuid())

  dahId     String?  @unique
  name      String

  premises  Premises[]

  createdAt DateTime @default(now())
}

model Premises {
  id                    String   @id @default(cuid())

  dahId                 String   @unique

  buildingId            String?
  building              Building? @relation(fields: [buildingId], references: [id])

  name                  String

  personalAccountNumber String?

  apartmentNumber       String?
  apartmentType         String?

  sectionNumber         String?
  sectionType           String?

  floor                 Int?

  size                  Float?

  debtor                Boolean?
  printReceipt          Boolean?

  meters                Meter[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([apartmentNumber])
}

model Meter {
  id                    String       @id @default(cuid())

  dahId                 String       @unique

  premisesId            String
  premises              Premises     @relation(fields: [premisesId], references: [id])

  name                  String?

  resourceType          ResourceType

  dateInitialIndication DateTime?

  history               MeterHistory[]

  collectedReadings     CollectedReading[]

  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([resourceType])
}

model MeterHistory {
  id            String        @id @default(cuid())

  meterId       String
  meter         Meter         @relation(fields: [meterId], references: [id])

  period        String

  startValue    Float
  endValue      Float
  consumed      Float

  source        ReadingSource @default(DAH)

  importedAt    DateTime @default(now())

  @@index([meterId])
  @@index([period])
  @@unique([meterId, period])
}

model CollectionSession {
  id            String          @id @default(cuid())

  name          String

  resourceType  ResourceType

  status        SessionStatus   @default(DRAFT)

  readings      CollectedReading[]

  createdAt     DateTime @default(now())
  completedAt   DateTime?
}

model CollectedReading {
  id              String          @id @default(cuid())

  sessionId       String
  session         CollectionSession @relation(fields: [sessionId], references: [id])

  meterId         String
  meter           Meter           @relation(fields: [meterId], references: [id])

  previousValue   Float

  enteredValue    Float

  difference      Float

  status          ReadingStatus   @default(OK)

  comment         String?

  createdAt       DateTime @default(now())

  exportQueue     ExportQueue?

  @@index([sessionId])
  @@index([meterId])
}

enum ExportStatus {
  PENDING
  SENT
  ERROR
}

model ExportQueue {
  id                  String @id @default(cuid())

  readingId           String @unique
  reading             CollectedReading @relation(fields: [readingId], references: [id])

  status              ExportStatus @default(PENDING)

  attempts            Int @default(0)

  error               String?

  exportedAt          DateTime?

  createdAt           DateTime @default(now())
}